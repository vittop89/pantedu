{
  "_description": "Internal schema definitions for FisMatPant agent contracts",
  "version": "3.0.0",

  "FlatContract": {
    "description": "Output dell'estrazione immagine (Step 1 del workflow-manager)",
    "shape": {
      "type": "type_Collect | type_VF | type_RMultiA | type_RMultiB",
      "number": "string — da immagine",
      "page": "string — da config page_map",
      "difficulty": "string — da config difficulty_map (1-4)",
      "badge_color": "string — red|blue|green|orange",
      "topic": {
        "name": "string — da config topics",
        "existing": "boolean — da preflight",
        "insertNear": "string|null — ultimo esercizio dello stesso topic"
      },
      "source": {
        "code": "string — chiave SOURCES.json",
        "title": "string",
        "volume": "string",
        "publisher": "string",
        "authors": "string"
      },
      "scope_id": "string — id del target scope",
      "content": "object — struttura dipende dal type"
    },
    "content_shapes": {
      "type_Collect_single": {
        "question": "string",
        "data_table": "string — LaTeX tabella DATI & INCOGNITE (obbligatoria)",
        "steps": ["string — passaggi algebrici LaTeX con unità di misura e \\cancel{}"],
        "final_answer": "string"
      },
      "type_Collect_multi": {
        "question": "string",
        "data_table": "string — LaTeX tabella DATI & INCOGNITE (obbligatoria, con \\hdashline tra punti)",
        "points": [{ "label": "string", "steps": ["string"], "solution": "string" }]
      },
      "type_VF": {
        "statements": [{ "text": "string", "isTrue": "boolean", "explanation": "string" }]
      },
      "type_RMultiA": {
        "question": "string",
        "statements": [{ "letter": "string", "text": "string", "isTrue": "boolean|null", "explanation": "string" }]
      },
      "type_RMultiB": {
        "question": "string",
        "options": ["string"],
        "correctIndices": ["number"],
        "explanations": ["string"],
        "explanation": "string — fallback singolo se explanations assente"
      }
    }
  },

  "target_entries_mode": {
    "description": "Campo nei defaults di ogni target in template_exercise.json",
    "values": {
      "prefer": "Usa target_entries[] per matching deterministico se disponibili, altrimenti fallback su defaults generali",
      "strict": "Richiede match esatto in target_entries[], errore se non trovato",
      "ignore": "Ignora target_entries[], usa solo defaults generali"
    },
    "default": "prefer"
  },

  "ExerciseContract": {
    "description": "Input per il subagent exercise-builder (Step 2). Derivato da FlatContract normalizzato.",
    "shape": {
      "type": "string",
      "source": {
        "code": "string",
        "title": "string",
        "volume": "string",
        "publisher": "string",
        "authors": "string"
      },
      "metadata": {
        "difficulty": "string",
        "page": "string",
        "number": "string",
        "badge_color": "string",
        "topic": "string"
      },
      "content": "object — same shapes as FlatContract.content_shapes"
    }
  },

  "error_catalog": [
    { "code": "TARGET_MISMATCH",       "severity": "critical", "description": "Numeri richiesti in target_numbers non trovati nell'immagine" },
    { "code": "OUT_OF_SCOPE",          "severity": "warning",  "description": "Numero estratto non presente in target_numbers" },
    { "code": "IMAGE_NOT_READABLE",    "severity": "error",    "description": "Immagine allegata non accessibile" },
    { "code": "NUMBER_NOT_FOUND",      "severity": "error",    "description": "Numero esercizio non rilevato dall'immagine" },
    { "code": "TYPE_AMBIGUOUS",        "severity": "error",    "description": "Tipo esercizio non determinabile" },
    { "code": "AMBIGUOUS_TARGET_ENTRY","severity": "critical", "description": "Target entry ambigua per matching" },
    { "code": "CONTAINER_NOT_FOUND",   "severity": "critical", "description": "Container HTML non trovato nel PHP target" },
    { "code": "FILE_NOT_READABLE",     "severity": "critical", "description": "File PHP target non leggibile" },
    { "code": "MISSING_REQUIRED_FIELD","severity": "critical", "description": "Campo obbligatorio assente nel contract" },
    { "code": "CONTEXT_STALE",         "severity": "critical", "description": "Checksum PHP target non corrisponde al preflight" }
  ],

  "error_format": {
    "code": "string — from error_catalog",
    "severity": "critical | error | warning",
    "human_message": "string — messaggio leggibile",
    "details": "object — contesto aggiuntivo"
  }
}
