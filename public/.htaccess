# Pantedu — public front controller
Options -Indexes +FollowSymLinks
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Skip real files/dirs in /public only (static assets live outside this dir)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else through the front controller
    RewriteRule ^ index.php [L]
</IfModule>

# Security headers (Phase 19 — allineato con root .htaccess)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
    # 2026-06-03 — Content-Security-Policy RIMOSSA da .htaccess: fonte unica =
    # SecurityHeadersMiddleware (PHP). Necessario per il nonce per-request
    # (uno static Header non può generare nonce). Tutte le risposte HTML
    # passano dal front controller → il middleware setta sempre la CSP.

    # Phase 25.B7 — info disclosure mitigation (FND-003 pentest 2026-05-18)
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# Disable server signature
ServerSignature Off

# ════════════════════════════════════════════════════════════
# Perf 2026-05-24 — static asset cache lifetimes
# Vite bundles (filename con hash) + vendor pinned → immutable.
# Lighthouse "uses-long-cache-ttl" segnalava 474KiB risparmio.
# ════════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    # Vite bundles: filename con hash (es. bootstrap.DZc-ltCX.js) → 1y immutable
    <FilesMatch "\.[a-zA-Z0-9_-]{6,}\.(js|mjs|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Font files (sempre cacheable a lungo)
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Images
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
        Header setIfEmpty Cache-Control "public, max-age=15552000"
    </FilesMatch>
    # vendor/ libs pinned per versione (es. quill/1.3.6/)
    <If "%{REQUEST_URI} =~ m#^/vendor/[^/]+/[0-9]+\.[0-9]+#">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
</IfModule>
