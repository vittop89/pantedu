{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource (point to http://127.0.0.1:3100)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.5.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "pantedu-overview",
  "title": "pantedu — Overview (WAF + NIDS + nginx + deploy)",
  "tags": ["pantedu", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Nginx requests (last 1h)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"nginx\"} [1h]))"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] } }
      }
    },
    {
      "type": "stat",
      "title": "WAF blocks (last 1h)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"waf-blocked\"} [1h]))"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 50 }] } }
      }
    },
    {
      "type": "stat",
      "title": "Fail2ban bans (last 24h)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"fail2ban\"} |= \"Ban\" [24h]))"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }
      }
    },
    {
      "type": "stat",
      "title": "Suricata alerts (last 1h)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"suricata\"} |= \"\\\"event_type\\\":\\\"alert\\\"\" [1h]))"
        }
      ],
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 20 }] } }
      }
    },
    {
      "type": "timeseries",
      "title": "Nginx request rate (per minute)",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"nginx\"} [1m])) * 60",
          "legendFormat": "req/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "WAF blocks vs Fail2ban bans (per minute)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"waf-blocked\"} [1m])) * 60",
          "legendFormat": "WAF blocks/min"
        },
        {
          "refId": "B",
          "expr": "sum(rate({job=\"fail2ban\"} |= \"Ban\" [1m])) * 60",
          "legendFormat": "Fail2ban bans/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "logs",
      "title": "Suricata alerts (live)",
      "id": 7,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"suricata\"} |= \"\\\"event_type\\\":\\\"alert\\\"\"",
          "maxLines": 100
        }
      ],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "type": "logs",
      "title": "WAF blocked requests (live)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"waf-blocked\"}",
          "maxLines": 50
        }
      ],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "type": "logs",
      "title": "Fail2ban events (live)",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"fail2ban\"}",
          "maxLines": 50
        }
      ],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "type": "logs",
      "title": "Deploy webhook log (last events)",
      "id": 10,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"deploy\"}",
          "maxLines": 100
        }
      ],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
