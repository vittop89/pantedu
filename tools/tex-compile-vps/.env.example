# tex-compile-vps — environment variables
# Copia in /opt/tex-compile/.env sul VPS e personalizza.

# Segreto HMAC condiviso con il client (hosting legacy). Genera con:
#   openssl rand -hex 32
TEX_COMPILE_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Bind address e porta del servizio FastAPI (dietro nginx).
# NB: questi valori sono SOLO informativi — il systemd unit ha host/port
# hardcoded in ExecStart. Se vuoi cambiarli, edita anche tex-compile.service.
TEX_COMPILE_HOST=127.0.0.1
TEX_COMPILE_PORT=8001

# Numero massimo di compile concorrenti (semaforo applicativo).
# Adatta in base al numero di vCPU del VPS (consigliato: vCPU - 1).
TEX_COMPILE_MAX_CONCURRENCY=3

# Timeout massimo per singolo compile (secondi).
TEX_COMPILE_TIMEOUT=30

# Tolleranza timestamp HMAC (secondi). Richieste più vecchie scartate.
TEX_COMPILE_MAX_CLOCK_SKEW=300

# Engine LaTeX di default (override per request via campo "engine").
# Valori ammessi: pdflatex, xelatex, lualatex
TEX_COMPILE_DEFAULT_ENGINE=pdflatex

# Numero passate compile per risolvere referenze (\ref, \toc, ecc).
# 2 è standard; portare a 3 se si usa biblatex/biber.
TEX_COMPILE_PASSES=2

# Directory di lavoro per pdflatex (tmpdir per ogni compile).
# IMPORTANTE: deve essere sotto /tmp/ perché il systemd unit usa
# PrivateTmp=yes che rende /tmp e /var/tmp privati al servizio.
# Usare /var/tmp/* richiederebbe ReadWritePaths che entra in conflitto.
TEX_COMPILE_WORKDIR=/tmp/tex-compile

# Log level (DEBUG, INFO, WARNING, ERROR).
TEX_COMPILE_LOG_LEVEL=INFO
