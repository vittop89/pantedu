# Hetzner Cloud API config — usato da /usr/local/sbin/hetzner_snapshot.sh
#
# Installazione sul VPS:
#   1. Genera token su https://console.hetzner.cloud → Security → API Tokens
#      (permissions: Read + Write, scope = projecto specifico)
#   2. Copia questo file a /etc/pantedu/hetzner-api.env
#   3. Sostituisci i placeholder con i valori reali
#   4. chmod 600 + chown root:root
#
# NON COMMITTARE IN GIT il file completo — contiene secret API token.

# Hetzner Cloud API token (64 caratteri alphanum)
HETZNER_API_TOKEN="PASTE-YOUR-HCLOUD-TOKEN-HERE-64-CHARS"

# Server name su Hetzner Cloud Console (es. pantedu-app-nbg1-1)
# Per verificare: hcloud server list (richiede hcloud CLI installato)
HETZNER_SERVER_NAME="pantedu-app-nbg1-1"

# Quanti snapshot mantenere (auto-* + pre-deploy-*).
# Costo per snapshot: ~€1/mese (VPS 80GB × €0.017446/GB).
# Default 1 → ~€1/mese (minimizzato).
# Alza a 2 se vuoi una finestra di rollback più ampia (~€2/mese).
SNAPSHOT_RETENTION_COUNT="1"
