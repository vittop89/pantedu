% G27.listmk — marker liste a dimensione uniforme + default itemize ●○■.
% I simboli amssymb hanno taglie native molto diverse (\bullet/\circ piccoli,
% \blacksquare/\bigstar grandi): \fmmk normalizza l'ALTEZZA via \resizebox così
% i marker appaiono uniformi, coerenti con la resa a schermo (●○■ / ➤♦● / ★○■).
% La taglia (0.85ex) è tunabile.
\providecommand{\fmmk}[1]{\raisebox{0.12ex}{\resizebox{!}{0.85ex}{\ensuremath{#1}}}}
% Default itemize (liste senza preset): cerchio pieno / vuoto / quadrato pieno.
% I preset espliciti (arrow-bullet/star-circle) sovrascrivono in scope locale.
\setlist[itemize,1]{label=\fmmk{\bullet}}
\setlist[itemize,2]{label=\fmmk{\circ}}
\setlist[itemize,3]{label=\fmmk{\blacksquare}}

