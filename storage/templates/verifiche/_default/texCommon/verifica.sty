% =============================================================================
% Counter copie: badge in basso a destra "stampe-{KIND}: {N}".
% Uso: nel main_VARIANT.tex chiama UNA volta \verificaCounterFooter{NOR}{3}
% o {SOL}/{DSA}/{DIS}. Centralizza la \AtBeginShipout in modo che ogni
% variante tex riferisca solo il proprio counter.
% =============================================================================
\newcommand{\verificaCounterFooter}[2]{%
  \AtBeginShipout{%
    \AtBeginShipoutUpperLeft{%
      \begin{tikzpicture}[remember picture, overlay]
        \node[anchor=south east, xshift=-0.5cm, yshift=0.5cm]
          at (current page.south east) {\textbf{stampe-#1: #2}};
      \end{tikzpicture}%
    }%
  }%
}

% =============================================================================
% Font setup centralizzato.
%
% Tutti i main_*.tex usano \verificaFontNormal in preambolo (helvetica sf).
% Le varianti DIS/DSA scopano il cambio font/interlinea SOLO attorno
% all'\input{esercizi_*} via gli env {dyslexicScope} / {dsaScope}, in modo
% che intestazione, ulteriori_misure, misure_dispensative e griglia restino
% nel font/spaziatura standard del documento.
%
% Per il main_DIS.tex la PRIMA RIGA deve essere `% !TeX program = xelatex`
% cosi' Overleaf / TeXstudio / VSCode LaTeX Workshop usano XeLaTeX
% automaticamente (no decommentare manuale).
% =============================================================================
\RequirePackage{iftex}

\newcommand{\verificaFontNormal}{%
  \ifxetex
    \RequirePackage{fontspec}%
    \setsansfont{Latin Modern Sans}[Scale=0.92]%
    \renewcommand{\familydefault}{\sfdefault}%
  \else\ifluatex
    \RequirePackage{fontspec}%
    \setsansfont{Latin Modern Sans}[Scale=0.92]%
    \renewcommand{\familydefault}{\sfdefault}%
  \else
    \usepackage[scaled]{helvet}%
    \usepackage[T1]{fontenc}%
    \renewcommand{\familydefault}{\sfdefault}%
  \fi\fi
}

% \verificaSetupFontDis: chiamare nel PREAMBOLO di main_DIS.tex.
% Carica fontspec (XeLaTeX/LuaLaTeX) e definisce \fontDis come selettore di
% font OpenDyslexic. Se OpenDyslexic non e' installato (o engine = pdflatex)
% \fontDis diventa \relax e il dyslexicScope cade sul sans-serif gia' attivo
% (helvet via \verificaFontNormal) con sola interlinea maggiorata.
\newcommand{\verificaSetupFontDis}{%
  \ifxetex
    \RequirePackage{fontspec}%
    \IfFontExistsTF{OpenDyslexic}{%
      \newfontfamily\fontDis{OpenDyslexic}%
    }{%
      \let\fontDis\relax%
    }%
  \else
    \ifluatex
      \RequirePackage{fontspec}%
      \IfFontExistsTF{OpenDyslexic}{%
        \newfontfamily\fontDis{OpenDyslexic}%
      }{%
        \let\fontDis\relax%
      }%
    \else
      % pdflatex: niente fontspec → fallback no-op (helvet rimane attivo)
      \let\fontDis\relax%
    \fi
  \fi
}

% Scope locale per dislessici: applica \fontDis (OpenDyslexic se disponibile)
% + interlinea 1.6, all'interno di un \begingroup. Tutto fuori dall'env resta
% nel font/spaziatura del documento.
\newenvironment{dyslexicScope}{%
  \par\begingroup
  \fontDis
  \renewcommand{\baselinestretch}{1.6}\selectfont
}{%
  \par\endgroup
}

% Scope locale per DSA: solo interlinea maggiorata (1.5), font invariato.
\newenvironment{dsaScope}{%
  \par\begingroup
  \renewcommand{\baselinestretch}{1.5}\selectfont
}{%
  \par\endgroup
}

% =============================================================================
% G27.badge — Badge editoriale: riquadro fonte + box numero esercizio +
% pallini difficolta'. Sostituisce il pattern LaTeX inline ripetuto a ogni
% esercizio nei file SOL.tex (\overset/\underset/\fcolorbox copincollati).
%
% Uso tipico (emesso da BadgeRenderer.php):
%   \badge[bg=green]{cdm_v4_ed1}{23}{342}{2}
%   \badge{mmb_v3_ed3}{145}{17}{1}
%
% Il src_key deve essere precedentemente registrato con \definefonte; in caso
% contrario il riquadro fonte cade su un placeholder visibile [fonte:KEY].
% =============================================================================

% \definefonte{KEY}{TITLE}{VOLUME}{AUTHORS}
% Registra una fonte nel namespace fmf@. Idempotente: una seconda chiamata
% sovrascrive (utile se il TexBuilder rigenera il preambolo a ogni save).
\newcommand{\definefonte}[4]{%
  \csdef{fmf@#1@title}{#2}%
  \csdef{fmf@#1@volume}{#3}%
  \csdef{fmf@#1@authors}{#4}%
  \csdef{fmf@#1@ok}{1}%
}

% Stile fontebox (xkeyval namespace fmfonte). Default = comportamento
% legacy. Override per-docente via \fmsetfonte{...} emesso da BadgeRenderer
% nel preambolo (block style in fonti_SOL.tex).
%   titlesize  font-size del titolo libro       (default \small)
%   metasize   font-size di volume/authors       (default \tiny)
%   rowsep     spaziatura verticale tra righe   (default -5pt; meno = più stretto)
%   colspec    column spec del riquadro array   (default |c|; alt: |p{4cm}| per fissare width)
%   vpad       padding verticale ESTERNO (sopra prima riga + sotto ultima),
%              dimension LaTeX (default 0pt). Es. 4pt → 4pt sopra il titolo
%              e 4pt sotto gli autori; tra le righe interne resta `rowsep`.
%              Implementato via \rule (strut invisibile), no impact su altri
%              array del documento.
\define@key{fmfonte}{titlesize}{\def\fmf@tsize{#1}}
\define@key{fmfonte}{metasize}{\def\fmf@msize{#1}}
\define@key{fmfonte}{rowsep}{\def\fmf@rsep{#1}}
\define@key{fmfonte}{colspec}{\def\fmf@cspec{#1}}
\define@key{fmfonte}{vpad}{\def\fmf@vpad{#1}}
\presetkeys{fmfonte}{titlesize=\small,metasize=\tiny,rowsep=-5pt,colspec=|c|,vpad=0pt}{}
% G27.bugfix — \presetkeys registra i defaults, ma i \def\fmf@xxx{...} vengono
% eseguiti SOLO al primo \setkeys{fmfonte}{...}. Senza chiamata esplicita, i
% \fmf@xxx restano undefined → \fontebox fallisce con "Undefined control sequence".
% Forziamo init dei defaults qui.
\setkeys{fmfonte}{}

% Setter pubblico: \fmsetfonte{titlesize=\footnotesize,rowsep=-3pt}
\newcommand{\fmsetfonte}[1]{\setkeys{fmfonte}{#1}}

% \fontebox{KEY} — riquadro con title/volume/authors. Uso in math mode
% (chiamato da \badge); placeholder grafico se KEY non registrata.
%
% G27.refactor — Passato da `array{|c|}\hline ... \hline\end{array}` a
% TikZ \node[draw, inner ysep=...] perche':
%   1. vpad (padding sopra/sotto) gestito nativamente da `inner ysep`,
%      senza spezzare bordi verticali (limite di \noalign{\vskip} nel
%      pattern array).
%   2. Bordo box pulito, line width controllabile.
%   3. Allineamento baseline garantito da `baseline=(fb.base)`.
%
% width: stringa vuota = auto-fit sul contenuto; altrimenti dim LaTeX
% (es. 4cm) → TikZ `text width=...`. Per back-compat la key colspec
% ancora esiste ma non e' piu' usata da \fontebox.
\newcommand{\fontebox}[1]{%
  \ifcsname fmf@#1@ok\endcsname
    \begingroup
    % G27.bugfix — baseline=(fb.center) allinea il riquadro fonte al
    % CENTRO verticale rispetto al badge numero esercizio (vs `fb.base`
    % che lo allineava sulla baseline dell'ultima riga "Authors", lasciandolo
    % visivamente in BASSO rispetto al badge \overset{bullets}{\underset{P-NN}{box}}).
    \begin{tikzpicture}[baseline=(fb.center)]%
      % NB: nessun \\[\fmf@rsep] dopo l'ULTIMA riga: causerebbe shift
      % verticale del bordo inferiore (rsep tipicamente negativo, -5pt,
      % tira il bordo inferiore sul testo). Lo spacing tra le righe
      % interne resta su rsep, padding esterno su inner ysep.
      %
      % inner ysep = base 1.5pt + vpad utente. Il base evita che bordo
      % tocchi il testo quando vpad=0pt (ascenders/descenders toccavano
      % la linea con inner ysep=0).
      \node[draw=black, line width=0.4pt, rectangle, align=center,
            inner xsep=4pt,
            inner ysep=\dimexpr 1.5pt+\fmf@vpad\relax] (fb) {%
        {\fmf@tsize\csname fmf@#1@title\endcsname}\\[\fmf@rsep]
        {\fmf@msize\csname fmf@#1@volume\endcsname}\\[\fmf@rsep]
        {\fmf@msize\csname fmf@#1@authors\endcsname}%
      };
    \end{tikzpicture}%
    \endgroup
  \else
    % Fallback: il key non viene stampato (avrebbe `_` underscore illegale
    % in text mode). Per debug consultare il log: BadgeRenderer emette i
    % key validi sanitizzati.
    \begin{tikzpicture}[baseline]%
      \node[draw=black, line width=0.4pt, inner xsep=4pt, inner ysep=2pt]
        {\fmf@msize[fonte non registrata]};
    \end{tikzpicture}%
  \fi
}

% \fmdots{N}{MAX} — bullets difficolta' (N filled \bullet, MAX-N empty \circ).
% Usa contatore dedicato per evitare collisioni con eventuali loop esterni.
\newcounter{fmdotsi}
\newcommand{\fmdots}[2]{%
  \setcounter{fmdotsi}{1}%
  \loop\ifnum\value{fmdotsi}<\numexpr#2+1\relax
    \ifnum\value{fmdotsi}>#1\relax\circ\else\bullet\fi
    \stepcounter{fmdotsi}%
  \repeat
}

% Opzioni \badge (xkeyval namespace fmbadge).
%   bg       colore xcolor di sfondo del box numero (default gray)
%   txt      colore xcolor del numero esercizio (default white)
%   exsize   font size del numero (default \large; alt: \Large, \huge)
%   minw     larghezza minima del box (default 1cm)
%   diffmax  totale pallini difficolta' (default 4)
%   diffsize font size dei pallini difficolta' (default \huge; alt: \Huge,\LARGE)
\define@key{fmbadge}{bg}{\def\fmb@bg{#1}}
\define@key{fmbadge}{txt}{\def\fmb@txt{#1}}
\define@key{fmbadge}{exsize}{\def\fmb@exsz{#1}}
\define@key{fmbadge}{minw}{\def\fmb@minw{#1}}
\define@key{fmbadge}{diffmax}{\def\fmb@dmax{#1}}
\define@key{fmbadge}{diffsize}{\def\fmb@dsz{#1}}
\presetkeys{fmbadge}{bg=gray,txt=white,exsize=\large,minw=1cm,diffmax=4,diffsize=\huge}{}
% G27.bugfix — init explicit dei defaults (vedi commento analogo su fmfonte sopra).
\setkeys{fmbadge}{}

% Setter pubblico globale: \fmsetbadge{bg=blue,exsize=\Large,minw=1.5cm}
% Sovrascrive i default per TUTTI i \badge successivi (senza override [opt]).
\newcommand{\fmsetbadge}[1]{\presetkeys{fmbadge}{#1}{}}

% \badge[opt]{src_key}{page}{ex_num}{difficulty}
% Inline-safe: \ensuremath wrappa il contenuto in math mode anche se chiamato
% da text mode (caso tipico: dopo \item nel body esercizi).
% NB: \huge prima di \fmdots emette warning "invalid in math mode" ma
% produce comunque output a dimensione large; replica fedelmente il pattern
% legacy SOL.tex (vedi tex_pdf/.../mat-2sc-v01-___-SOL.tex per riferimento).
\newcommand{\badge}[5][]{%
  \begingroup
    \setkeys{fmbadge}{#1}%
    \ensuremath{%
      % G27.bugfix — entrambi i sub-elementi (fontebox + badge composto)
      % wrappati in \vcenter{\hbox{...}} per allineamento sull'asse
      % matematico. Senza, il fontebox restava a baseline mentre il
      % badge composto (overset/underset) si estendeva sopra (bullets) e
      % sotto (P-NN) lasciando il fontebox visivamente in basso.
      % G27.badge — ordine badge→fonte (difficolta'+pagina+numero PRIMA, poi
      % fonte/book): coerente con il rendering inline a schermo (ContractRenderer,
      % richiesta utente 2026-06-04 "prima il badge poi la fonte").
      \vcenter{\hbox{$%
        \overset{\color{red}\fmb@dsz\fmdots{#5}{\fmb@dmax}}{%
          \underset{\text{P-#3}}{%
            \fcolorbox{white}{\fmb@bg}{%
              \makebox[\fmb@minw][c]{%
                \textcolor{\fmb@txt}{\fmb@exsz #4}%
              }%
            }%
          }%
        }%
      $}}\quad
      \vcenter{\hbox{\fontebox{#2}}}\quad
    }%
  \endgroup
}
