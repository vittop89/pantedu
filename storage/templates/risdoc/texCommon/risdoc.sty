% Babel italiano via caricamento MODERNO basato su .ini (\babelprovide):
% il TeX Live del servizio di compilazione non ha il classico italian.ldf
% (texlive-lang-european non lo fornisce) → `\usepackage[italian]{babel}`
% dava "! Package babel Error: Unknown option 'italian'". babel-italian.tex
% (locale) è presente → \babelprovide importa la lingua. Output equivalente.
\RequirePackage{babel}
\babelprovide[import, main]{italian}
