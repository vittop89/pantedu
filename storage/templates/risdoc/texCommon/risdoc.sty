% --- 3. DEFINIZIONE NUOVI TIPI DI COLONNA PER TABELLE ---
\newcolumntype{M}[1]{>{\centering\arraybackslash}m{#1}} % Centrata, larghezza fissa, allineata verticalmente al centro
\newcolumntype{C}{>{\centering\arraybackslash}X}      % Come X ma centrata
\newcolumntype{L}{>{\raggedright\arraybackslash}X}    % Come X ma allineata a sinistra
\newcolumntype{T}{>{\centering\arraybackslash}c}

% --- 4. COMANDI PERSONALIZZATI ---
\newcommand{\prevyear}{\the\numexpr\year-1\relax} % Anno precedente
\newcommand{\nextyear}{\the\numexpr\year+1\relax} % Anno successivo
\newcommand{\thisyear}{\the\year} % Anno corrente

% Comando per l'anno scolastico: 
% Se siamo tra settembre e dicembre: anno corrente/anno successivo
% Se siamo tra gennaio e agosto: anno precedente/anno corrente
\newcommand{\schoolyear}{%
  \ifnum\month<9
    \prevyear/\thisyear%
  \else
    \thisyear/\nextyear%
  \fi
}

% G27.listmk — marker liste a dimensione uniforme + default itemize ●○■.
% \fmmk normalizza l'altezza dei simboli amssymb (taglie native molto diverse)
% via \resizebox → marker uniformi, coerenti con la resa a schermo. SORGENTE
% condivisa con verifica.sty (vedi Sanitizer::listLabel / PtToTex).
\providecommand{\fmmk}[1]{\raisebox{0.12ex}{\resizebox{!}{0.85ex}{\ensuremath{#1}}}}
\setlist[itemize,1]{label=\fmmk{\bullet}}
\setlist[itemize,2]{label=\fmmk{\circ}}
\setlist[itemize,3]{label=\fmmk{\blacksquare}}

\newcommand{\simplefield}[2]{\par\noindent\textbf{#1}: #2} % Comando per un campo semplice (es. Classe: [valore])
\newcommand{\fillfield}[1]{\par\noindent\hangindent=2em\hangafter=0 #1 \dotfill} % Stile per i campi da compilare con linee punteggiate
\newcommand{\checkbox}{%
    \begin{tikzpicture}[baseline=0]
        \draw (0,0) rectangle (1.5ex,1.5ex);
    \end{tikzpicture}%
}
\newcommand{\xcheckbox}{%
    \begin{tikzpicture}[baseline=0]
        \draw (0,0) rectangle (1.5ex,1.5ex);
        \draw (0,0) -- (1.5ex,1.5ex);
        \draw (0,1.5ex) -- (1.5ex,0);
    \end{tikzpicture}%
}
\newcommand{\itemcheckbox}[1]{%
  \ifnum#1=1
    \item[\checkbox]
  \else
    \item[\xcheckbox]
  \fi
}

