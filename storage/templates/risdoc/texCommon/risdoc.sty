\RequirePackage{graphicx} % Per includere immagini
\RequirePackage{calc}     % Per calcoli con le dimensioni (es. per \myarraystretch * \height)
\RequirePackage{enumitem} % Per liste personalizzate
\RequirePackage{multicol} % Gruppi di checkbox su 2 colonne (\begin{multicols}{2})
\RequirePackage{amsmath}
\RequirePackage{amssymb} % Simboli liste ($\blacksquare$, $\rightarrow$, $\diamond$, $\star$, $\circ$) — preset elenchi PT
