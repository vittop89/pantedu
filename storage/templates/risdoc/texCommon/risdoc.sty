% 5.1.1 DEFINIZIONE E CALCOLO DELLE DIMENSIONI VERTICALI
% Ora che il box è pieno, possiamo misurarlo e calcolare l'altezza della riga.
%======================================================================
\newlength{\naturalmiddlecellheight} % Dimensione per l'altezza naturale del contenuto
\newlength{\targetrowheight}         % Dimensione per l'altezza finale desiderata della riga
% Misura l'altezza totale del box riempito e salva il valore.
\settototalheight{\naturalmiddlecellheight}{\usebox{\middlecellcontentbox}}
% Calcola l'altezza finale della riga, aggiungendo un po' di spazio verticale
\newcommand{\myarraystretch}{1.15} %    MODIFICA QUESTO VALORE SE DESIDERI UN ARRAYSTRETCH DIVERSO.
\setlength{\targetrowheight}{\myarraystretch\naturalmiddlecellheight}



% 5.2 STILE PER LE SEZIONI PRINCIPALI MODIFICATO
\newtcolorbox{sectionbox}[1]{
    enhanced,
    colback=white,
    colframe=borderColor,
    boxrule=0.5pt,
    sharp corners,
    valign=top,
    % Opzioni per il titolo e la sua "barra"
    title=#1,
    fonttitle=\bfseries\large,
    coltitle=titleTextColor,
    colbacktitle=colorBackTitleSec,
    %
    % Padding corretto per l'area del titolo
    toptitle=4pt,
    bottomtitle=4pt,
    lefttitle=3mm,
    %
    % Lo stile per la cornice del titolo
    boxed title style={
        sharp corners,
        boxrule=0.5pt,
        colframe=backGTitleSection, % In questo caso, la cornice è dello stesso colore dello sfondo
    },
    % Padding interno del contenuto
    left=3mm, right=3mm, top=2mm, bottom=3mm,
    % Spazio prima e dopo
    before=\par\medskip\noindent,
    after=\par\medskip,
    breakable
    % Opzionale: se vuoi che il titolo venga ripetuto sulla pagina successiva
    % break MODO = {
    %     title continuation = { (continua)}, % Testo da aggiungere al titolo sulla nuova pagina
    %     % Puoi anche specificare uno stile diverso per il titolo continuato
    % }
}
