APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.pantedu.eu
APP_TIMEZONE=Europe/Rome

# ─── Phase S2 Fase 2 — Data dir decoupling ───
# Path assoluto dove l'app cerca i dati (storage/, log/data/, eser/).
# Se vuoto → usa <repo>/storage etc. (backward-compat dev locale).
# In PRODUZIONE consigliato puntare FUORI dal repo per separare codice e dati:
#   PANTEDU_DATA_PATH=/var/lib/pantedu-data
# Layout atteso:
#   {PATH}/storage/verifiche_enc/{tid}/*.bin
#   {PATH}/storage/maps_enc/{tid}/*.bin
#   {PATH}/storage/objects/...
#   {PATH}/storage/data/*.json
#   {PATH}/log/data/*.json
#   {PATH}/eser/*/users/users.json
PANTEDU_DATA_PATH=

# ─── Phase S2 (ADR-017) — Deployment mode ───
# single    = singolo docente (S1, default sicuro, self-signup chiusa)
# institute = scuola multi-docente (S2, registration aperta con admin approve)
# Switch a runtime via /admin/system/deployment (super_admin only).
# Vedi wiki/decisions/ADR-017-deployment-mode-switch.md
DEPLOYMENT_MODE=single
# Email DPO scolastico — usato come contact in privacy notice + breach
# notification SOLO se DEPLOYMENT_MODE=institute. Se vuoto in institute mode,
# fallback su APP_MAIL_FROM.
INSTITUTE_OWNER_EMAIL=
# Ragione sociale scuola — mostrata in footer + DPA + privacy S2.
INSTITUTE_LEGAL_NAME=
# Nome operatore/gestore (data controller) in modo single S1 — mostrato nelle
# trust page (privacy/takedown). Lascia vuoto per etichetta generica.
INSTANCE_OPERATOR_NAME=

SESSION_LIFETIME=1800
SESSION_REGENERATE_INTERVAL=300
SESSION_COOKIE_NAME=PANTEDU_SID
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# Users are stored in log/data/admin_users.json, collaborators.json,
# and eser/{folder}/eser_{code}/users/users.json (one per class).
# Generate new hashes via: php tools/generate_password_hash.php "password"

CSRF_TOKEN_LIFETIME=7200
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

LOG_LEVEL=info
LOG_MAX_ENTRIES=1000
LOG_RETENTION_DAYS=30

# Phase 25.C8 — Email outbound (parent_consent + breach + general flows).
# Se APP_MAIL_FROM è vuoto, gli invii email vengono saltati (token + body
# loggati su storage/logs/mail_audit.log per recupero manuale).
# Su Aruba Basic Linux: usa l'indirizzo verificato del dominio.
APP_MAIL_FROM=
APP_MAIL_FROM_NAME=Pantedu

# ─────────────────────────────────────────────────────────────────────
# Phase 25 — security/quality toggles (default = warn/relaxed safe per
# rollout; raccomandato in PRODUZIONE i valori commentati a destra)
# ─────────────────────────────────────────────────────────────────────

# Phase 25.B4 — audit reason header X-Audit-Reason (admin POST/DELETE)
#   warn (default rollout): logga assenza ma procede
#   enforce (raccomandato prod): 403 se header mancante o invalido
#   disabled: skip (rollback)
AUDIT_REASON_MODE=warn                 # PROD recommended: enforce

# Phase 25.B5 — rate-limit bypass (mai abilitare in produzione!)
#   1 = bypass tutti i rate limiter (uso dev/CI/E2E)
#   unset/0 = limiti applicati
RATE_LIMIT_DISABLED=0                  # PROD recommended: unset (default 0)

# Phase 25.B6 — Content Security Policy mode (security.csp_mode override)
#   relaxed (default): permette inline scripts legacy (jQuery, Quill, ecc.)
#   strict: blocca inline (richiede cleanup completo, Phase 25.A finale)
#   report-only: monitoring senza enforcement (per tuning pre-strict)
CSP_MODE=relaxed                       # PROD recommended (post cleanup): strict

# Phase 25.D — Crypto envelope (KMS_MASTER in .env.local, non qui!)
#   CRYPTO_DUAL_WRITE=1 → writer plaintext + ciphertext (rollout)
#   CRYPTO_READ_FROM=plaintext|ciphertext (post-backfill: ciphertext)
CRYPTO_DUAL_WRITE=0                    # PROD post-backfill: 1
CRYPTO_READ_FROM=plaintext             # PROD post-backfill: ciphertext

# Phase 25.E4.2 — /metrics Prometheus auth (Bearer token o super_admin session)
METRICS_BEARER_TOKEN=                  # PROD: random 32+ hex generato

# Phase 25.E4.3 — Telemetry span emission (zero overhead se 0)
TELEMETRY_ENABLED=0                    # PROD: 1 se hai pipeline log JSON

# ─────────────────────────────────────────────────────────────────────
# Phase G1 — Google Drive OAuth integration (mappe + risdoc/verifiche
# sync). Credenziali ottenibili in Google Cloud Console:
#   1. Crea progetto + abilita Google Drive API
#   2. APIs & Services > Credentials > Create OAuth client ID (Web app)
#   3. Authorized redirect URIs: <APP_URL>/teacher/drive/callback
# Mantieni client_id/secret in .env.local (NON in .env), perche' .env e'
# committato nel repo.
# ─────────────────────────────────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=             # Opzionale; se vuoto, derivato da APP_URL

# ─────────────────────────────────────────────────────────────────────
# Phase G21 — tex-compile-vps (server-side LaTeX compile via VPS dedicato).
# Microservizio HMAC-protected che riceve .tex e ritorna PDF compilato.
# Codice sorgente: tools/tex-compile-vps/
# Deploy:          tools/tex-compile-vps/DEPLOY.md
#
# Se vuoti → integrazione disabilitata (button TEX/PDF salva solo TEX).
# Mantenere il segreto in .env.local (NON in .env committato).
#
# 2026-05-24 — VPS consolidato: uvicorn ascolta su 127.0.0.1:8001 sullo
# STESSO host che serve pantedu.eu. In PROD usa loopback (no nginx, no TLS).
# Hostname legacy `tex.pantedu.eu` rimosso dal DNS — non riutilizzarlo.
# Per dev XAMPP locale: lasciare vuoto (no microservizio raggiungibile)
# oppure tunnel SSH (es. `ssh -L 8001:127.0.0.1:8001 pantedu-vps`).
# ─────────────────────────────────────────────────────────────────────
TEX_COMPILE_ENDPOINT=                  # prod: http://127.0.0.1:8001 (no trailing /)
TEX_COMPILE_SECRET=                    # 64-char hex, vedi /opt/tex-compile/.env sul VPS
TEX_COMPILE_TIMEOUT=60                 # secondi, default 60 (margine TikZ)
TEX_COMPILE_ENGINE=pdflatex            # pdflatex|xelatex|lualatex (default pdflatex)
TEX_COMPILE_PASSES=2                   # passate per \ref/\toc (default 2)

# ─────────────────────────────────────────────────────────────────────
# Phase PDF-Import — estrazione esercizi da PDF via LLM vision (PHP-nativo).
# Tool teacher-only su /teacher/pdf-import. Multi-provider; le CHIAVI vivono
# SOLO qui in .env (mai sul client). Disabilitato di default.
# Hardening: budget token/giorno, allowlist Ollama (SSRF), SHA-256 (no MD5).
# ─────────────────────────────────────────────────────────────────────
PDF_IMPORT_ENABLED=false               # true per abilitare la feature
PDF_IMPORT_DEFAULT_PROVIDER=anthropic  # anthropic|openai|ollama
PDF_IMPORT_MAX_PAGES=40                # cap pagine per sessione
PDF_IMPORT_MAX_PDF_BYTES=26214400      # cap dimensione upload (25 MiB)
PDF_IMPORT_DPI=300                     # risoluzione rasterizzazione PDF→PNG
PDF_IMPORT_PROVIDER_TIMEOUT=90         # timeout HTTP (s) per chiamata vision
PDF_IMPORT_RETENTION_DAYS=7            # TTL: il worker cancella file+righe oltre N giorni
PDF_IMPORT_DAILY_TOKENS=2000000        # budget token/giorno per docente (0=off)
PDF_IMPORT_ANTHROPIC_KEY=              # METTI in .env.local (sk-ant-...)
PDF_IMPORT_ANTHROPIC_MODEL=claude-opus-4-8
PDF_IMPORT_OPENAI_KEY=                 # METTI in .env.local (sk-...)
PDF_IMPORT_OPENAI_MODEL=gpt-4o
# Qwen via Alibaba Cloud Model Studio (DashScope, endpoint OpenAI-compatibile).
# Chiave da modelstudio.console.alibabacloud.com (API-KEY, sk-...). Anche via popup.
PDF_IMPORT_QWEN_KEY=                   # METTI in .env.local (sk-...)
PDF_IMPORT_QWEN_MODEL=qwen-vl-max     # o qwen-vl-plus / qwen2.5-vl-72b-instruct
# Internazionale (default) vs Cina: .../dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
PDF_IMPORT_QWEN_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
# OpenRouter — gateway OpenAI-compatibile multi-modello. Chiave: openrouter.ai/keys.
# Model-ID (vendor/model) da openrouter.ai/models. Anche via popup (chiave+modello).
PDF_IMPORT_OPENROUTER_KEY=             # METTI in .env.local (sk-or-...)
PDF_IMPORT_OPENROUTER_MODEL=google/gemini-2.0-flash-001
PDF_IMPORT_OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
PDF_IMPORT_OLLAMA_ENABLED=false        # opt-in: considera Ollama un provider pronto
PDF_IMPORT_OLLAMA_BASE_URL=http://127.0.0.1:11434
PDF_IMPORT_OLLAMA_MODEL=qwen2.5vl:7b
PDF_IMPORT_OLLAMA_ALLOWED_HOSTS=127.0.0.1,localhost  # SSRF allowlist host Ollama
# Le chiavi cloud possono anche essere impostate da UI (popup admin sulla pagina
# /teacher/pdf-import) → salvate in storage/config/pdf_import_keys.json (0600).

# ─────────────────────────────────────────────────────────────────────
# Phase 25.C — WAF self-hosted (GeoIP + Fingerprinting + Scoring + Rules)
# Implementazione: docs/todo/waf_security_prompt.md
# Toggle operativi (enabled, mode, soglie, geo allowed): tabella `waf_config`
# editabile via pannello /admin/waf (super_admin only).
# Qui SOLO i segreti runtime.
# ─────────────────────────────────────────────────────────────────────
# HMAC key per firmare cookie waf_session (>= 32 byte).
# Genera: openssl rand -hex 32. NON committare il valore reale.
WAF_HMAC_SECRET=
# Path DB GeoIP locale formato .mmdb. Vuoto = no GeoIP DB locale (fallback
# su header CF-IPCountry / X-GeoIP-Country o disable geo).
#
# Opzione A — db-ip.com Lite (NO signup, free monthly, raccomandato):
#   mkdir -p storage/geoip
#   curl -sL "https://download.db-ip.com/free/dbip-country-lite-$(date +%Y-%m).mmdb.gz" \
#     | gunzip > storage/geoip/dbip-country-lite.mmdb
#   WAF_GEOIP_DB=/var/www/pantedu/storage/geoip/dbip-country-lite.mmdb
#
# Opzione B — MaxMind GeoLite2 (signup su maxmind.com + geoipupdate cron):
#   WAF_GEOIP_DB=/etc/GeoIP/GeoLite2-Country.mmdb
WAF_GEOIP_DB=

# WAF_GEOIP_ASN_DB — path al .mmdb ASN per enrichment "RDNS & ASN"
# (admin toggle nelle tabelle IP). Free download db-ip.com:
#   curl -sL "https://download.db-ip.com/free/dbip-asn-lite-$(date +%Y-%m).mmdb.gz" \
#     | gunzip > storage/geoip/dbip-asn-lite.mmdb
#   WAF_GEOIP_ASN_DB=/var/www/pantedu/storage/geoip/dbip-asn-lite.mmdb
WAF_GEOIP_ASN_DB=

# ─────────────────────────────────────────────────────────────────────
# Database (MariaDB / MySQL) — credenziali in .env.local (NON qui)
# ─────────────────────────────────────────────────────────────────────
DB_ENABLED=true
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pantedu
DB_USER=pantedu
DB_PASS=                               # METTI in .env.local
DB_CHARSET=utf8mb4
DB_DUAL_WRITE=false                    # true solo durante migrazione JSON→MySQL

# ─────────────────────────────────────────────────────────────────────
# Crypto envelope — KMS_MASTER_KEY E STORAGE_SIGNING_SECRET in .env.local!
# Genera entrambi con: openssl rand -hex 32
# IMPORTANTE: perdita di KMS_MASTER_KEY = perdita irreversibile di TUTTI
# i contenuti cifrati. Setup recovery 3-of-5 in
# docs/security/operations/shamir-recovery-runbook.md
# ─────────────────────────────────────────────────────────────────────
KMS_MASTER_KEY=                        # METTI in .env.local (64-hex)
STORAGE_SIGNING_SECRET=                # METTI in .env.local (64-hex)
ALLOW_CRYPTO_REGENERATE=0              # 1 solo per bypass safeguard (DEV)

# Dev-only: esporre token deletion debug (mai in PROD)
EXPOSE_DELETION_DEBUG_TOKEN=0

# ─────────────────────────────────────────────────────────────────────
# Phase D.2 — SPID + CIE federated identity (disabled fino a AgID SP).
# Vedi docs/plans/d2-spid-cie-integration.md.
# Cert + key in /etc/pantedu/spid/ + /etc/pantedu/cie/ (perm 0600, root)
# NEVER committed.
# ─────────────────────────────────────────────────────────────────────
SPID_ENABLED=0
SPID_SP_ENTITY_ID=https://pantedu.eu/auth/spid/metadata
SPID_SP_CERT_PATH=/etc/pantedu/spid/sp.crt
SPID_SP_KEY_PATH=/etc/pantedu/spid/sp.key
SPID_SP_ORGANIZATION="Pantedu — Piattaforma educativa"
SPID_SP_TECH_CONTACT_EMAIL=dpo@pantedu.eu
# Attributi minimi richiesti per docente PA target.
SPID_REQUESTED_ATTRIBUTES=name,familyName,fiscalNumber,dateOfBirth,email
# SPID auth level: 1=basic 2=username+OTP 3=high (smart card)
SPID_REQUESTED_AUTH_LEVEL=2

CIE_ENABLED=0
CIE_SP_ENTITY_ID=https://pantedu.eu/auth/cie/metadata
CIE_SP_CERT_PATH=/etc/pantedu/cie/sp.crt
CIE_SP_KEY_PATH=/etc/pantedu/cie/sp.key
# CIE auth level: L1 = app + CIE PIN, L2 = NFC + PIN, L3 = qual cert
CIE_REQUESTED_AUTH_LEVEL=L2

# ─── Phase Roadmap 9 — Critical CSS opt-in ────────────────────────────
# Inline css/critical.css in <head> + async load main.css. Riduce FCP
# ~1.5s su Slow 3G. Rollback istantaneo cambiando a 0.
# Test su staging prima di abilitare in produzione.
FM_CRITICAL_CSS=0

# ─── Phase Roadmap — Web Vitals RUM endpoint ──────────────────────────
# Endpoint POST /api/vitals salva ndjson in logs/web-vitals/YYYY-MM-DD.
# 0 = endpoint accetta ma scarta (dev). 1 = persist + ingest Loki.
FM_VITALS_ENABLED=1

# ─── Phase Roadmap 13 — HTTP/3 (richiede nginx >=1.25 con http_v3) ────
# Quando nginx VPS upgraded, decommenta `listen 443 quic` in
# infra/nginx/pantedu.eu.conf e set FM_HTTP3_ENABLED=1 (per Alt-Svc).
FM_HTTP3_ENABLED=0
