            "time_window_minutes": 30,
            "risk_levels": {
                "low": {
                    "min_attempts": 10,
                    "max_attempts": 20
                },
                "medium": {
                    "min_attempts": 21,
                    "max_attempts": 50
                },
                "high": {
                    "min_attempts": 51,
                    "max_attempts": 999999
                }
            }
        }
