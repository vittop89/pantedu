            "threshold_per_section": 2,
            "time_window_hours": 24,
            "risk_levels": {
                "low": {
                    "min_accesses": 3,
                    "max_accesses": 25
                },
                "medium": {
                    "min_accesses": 26,
                    "max_accesses": 50
                },
                "high": {
                    "min_accesses": 51,
                    "max_accesses": 999999
                }
            }
        },
        "credential_sharing": {
            "enabled": true,
            "description": "Rileva quando le stesse credenziali vengono utilizzate da molti IP diversi",
            "min_ips_required": 5,
            "min_accesses_per_ip": 2,
            "time_window_hours": 24,
            "risk_levels": {
                "low": {
                    "min_ips": 5,
                    "max_ips": 7
                },
                "medium": {
                    "min_ips": 8,
                    "max_ips": 10
                },
                "high": {
                    "min_ips": 11,
                    "max_ips": 999999
                }
            }
        },
