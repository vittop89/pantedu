            "risk_levels": {
                "low": {
                    "min_accesses": 10,
                    "max_accesses": 20
                },
                "medium": {
                    "min_accesses": 21,
                    "max_accesses": 50
                },
                "high": {
                    "min_accesses": 51,
                    "max_accesses": 999999
                }
            }
        },
        "suspicious_patterns": {
            "enabled": false,
