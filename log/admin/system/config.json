                "end_hour": 6,
                "min_accesses": 5
            },
            "suspicious_user_agents": {
                "enabled": true,
                "patterns": [
                    "bot",
                    "crawler",
                    "spider",
                    "scraper",
                    "curl",
                    "wget"
